rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Match history: users/{uid}/matches/{matchId}
    // Only the signed-in owner (Google or anonymous) may read/write their own matches.
    match /users/{uid}/matches/{matchId} {
      allow read, delete: if request.auth != null && request.auth.uid == uid;

      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(['date','teamA','teamB','resultText','winner','manOfMatch','innings'])
        && request.resource.data.date is number
        && request.resource.data.teamA is string
        && request.resource.data.teamB is string
        && request.resource.data.innings is list;

      // Match history entries are immutable once written.
      allow update: if false;
    }

    // In-progress matches: users/{uid}/liveMatches/{matchId}
    // Written continuously while scoring so the owner can resume the same
    // match from a different device. Unlike match history this is a mutable
    // working document, deleted once the match is recorded to history or
    // abandoned.
    match /users/{uid}/liveMatches/{matchId} {
      allow read, write, delete: if request.auth != null && request.auth.uid == uid;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
